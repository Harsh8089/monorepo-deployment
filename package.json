{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prisma:generate": "cd packages/db && pnpm run generate", 
    "prisma:migrate:deploy": "cd packages/db && pnpm run migrate:deploy",
    "start:be": "pnpm run prisma:migrate:deploy && cd apps/http && pnpm run start",
    "start:fe": "cd apps/web && pnpm dev"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.9.12",
    "typescript": "5.5.4"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "with-vite-react"
}
